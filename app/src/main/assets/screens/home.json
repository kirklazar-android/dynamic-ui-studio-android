{
  "screenId": "home",
  "title": "DynamicUI Studio",
  "version": 1,
  "analytics": {
    "screenView": "home_v1"
  },
  "layout": {
    "type": "vertical",
    "padding": 20,
    "widgets": [
      {
        "id": "hero_1",
        "type": "hero_banner",
        "title": "Welcome Back",
        "subtitle": "Your dashboard is rendered from a JSON contract at runtime.",
        "actionText": "View details",
        "action": {
          "type": "show_snackbar",
          "message": "Hero action clicked"
        }
      },
      {
        "id": "text_1",
        "type": "text",
        "text": "This screen is composed dynamically using schema models, validation, and a Compose widget registry.",
        "style": "body"
      },
      {
        "id": "capabilities_card",
        "type": "card",
        "children": [
          {
            "id": "capabilities_title",
            "type": "text",
            "text": "Current renderer capabilities",
            "style": "title"
          },
          {
            "id": "capabilities_list",
            "type": "list",
            "items": [
              "Schema parsing",
              "Widget registry rendering",
              "Dynamic action handling",
              "Validation before rendering"
            ]
          }
        ]
      },
      {
        "id": "button_1",
        "type": "button",
        "text": "Continue",
        "analytics": {
          "click": "home_continue_clicked"
        },
        "action": {
          "type": "show_snackbar",
          "message": "CTA clicked"
        }
      }
    ]
  }
}
